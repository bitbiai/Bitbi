{
  "schemaVersion": 1,
  "release": {
    "schemaCheckpoints": {
      "auth": {
        "migrationDirectory": "workers/auth/migrations",
        "latest": "0043_add_news_pulse_items.sql",
        "databaseName": "bitbi-auth-db"
      }
    },
    "workers": {
      "ai": {
        "name": "bitbi-ai",
        "wranglerPath": "workers/ai/wrangler.jsonc",
        "workersDev": false,
        "previewUrls": false,
        "bindings": {
          "ai": "AI",
          "durableObjects": {
            "SERVICE_AUTH_REPLAY": {
              "className": "AiServiceAuthReplayDurableObject"
            }
          }
        },
        "migrations": [
          {
            "tag": "v1-service-auth-replay",
            "newSqliteClasses": ["AiServiceAuthReplayDurableObject"]
          }
        ]
      },
      "auth": {
        "name": "bitbi-auth",
        "wranglerPath": "workers/auth/wrangler.jsonc",
        "vars": ["APP_BASE_URL", "RESEND_FROM_EMAIL", "BITBI_ENV"],
        "expectedVars": {
          "APP_BASE_URL": "https://bitbi.ai",
          "RESEND_FROM_EMAIL": "BITBI <noreply@contact.bitbi.ai>",
          "BITBI_ENV": "production"
        },
        "triggers": {
          "crons": ["0 3 * * *"]
        },
        "routes": [
          {
            "pattern": "bitbi.ai/api/*",
            "zone_name": "bitbi.ai"
          }
        ],
        "bindings": {
          "ai": "AI",
          "images": "IMAGES",
          "d1": {
            "DB": {
              "databaseName": "bitbi-auth-db"
            }
          },
          "r2": {
            "PRIVATE_MEDIA": {
              "bucketName": "bitbi-private-media"
            },
            "USER_IMAGES": {
              "bucketName": "bitbi-user-images"
            },
            "AUDIT_ARCHIVE": {
              "bucketName": "bitbi-audit-archive"
            }
          },
          "services": {
            "AI_LAB": {
              "service": "bitbi-ai",
              "worker": "ai"
            }
          },
          "durableObjects": {
            "PUBLIC_RATE_LIMITER": {
              "className": "AuthPublicRateLimiterDurableObject"
            }
          },
          "queues": {
            "producers": {
              "ACTIVITY_INGEST_QUEUE": {
                "queue": "bitbi-auth-activity-ingest"
              },
              "AI_IMAGE_DERIVATIVES_QUEUE": {
                "queue": "bitbi-ai-image-derivatives"
              },
              "AI_VIDEO_JOBS_QUEUE": {
                "queue": "bitbi-ai-video-jobs"
              }
            },
            "consumers": [
              {
                "queue": "bitbi-auth-activity-ingest",
                "max_batch_size": 50,
                "max_batch_timeout": 5,
                "max_retries": 6
              },
              {
                "queue": "bitbi-ai-image-derivatives",
                "max_batch_size": 5,
                "max_batch_timeout": 5,
                "max_retries": 8
              },
              {
                "queue": "bitbi-ai-video-jobs",
                "max_batch_size": 3,
                "max_batch_timeout": 5,
                "max_retries": 4
              }
            ]
          }
        },
        "migrations": [
          {
            "tag": "v1-public-rate-limiter",
            "newSqliteClasses": ["AuthPublicRateLimiterDurableObject"]
          }
        ]
      },
      "contact": {
        "name": "bitbi-contact",
        "wranglerPath": "workers/contact/wrangler.jsonc",
        "vars": ["BITBI_ENV"],
        "expectedVars": {
          "BITBI_ENV": "production"
        },
        "workersDev": false,
        "routes": [
          {
            "pattern": "contact.bitbi.ai",
            "custom_domain": true
          }
        ],
        "bindings": {
          "durableObjects": {
            "PUBLIC_RATE_LIMITER": {
              "className": "ContactPublicRateLimiterDurableObject"
            }
          }
        },
        "migrations": [
          {
            "tag": "v1-public-rate-limiter",
            "newSqliteClasses": ["ContactPublicRateLimiterDurableObject"]
          }
        ]
      }
    },
    "deployOrder": [
      {
        "id": "auth-migrations",
        "type": "schema-checkpoint",
        "checkpoint": "auth"
      },
      {
        "id": "ai-worker",
        "type": "worker",
        "worker": "ai"
      },
      {
        "id": "auth-worker",
        "type": "worker",
        "worker": "auth",
        "dependsOn": ["auth-migrations", "ai-worker"]
      },
      {
        "id": "contact-worker",
        "type": "worker",
        "worker": "contact"
      },
      {
        "id": "static-site",
        "type": "static",
        "dependsOn": ["auth-worker", "contact-worker"]
      }
    ],
    "manualPrerequisites": [
      {
        "id": "auth-session-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "SESSION_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Legacy compatibility fallback for pre-Phase 1-D sessions, admin MFA material, cursors, and generated image save references. Keep until the legacy security-secret fallback is intentionally disabled after the migration window."
      },
      {
        "id": "auth-session-hash-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "SESSION_HASH_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Required for hashing new auth session tokens. New sessions must not use SESSION_SECRET."
      },
      {
        "id": "auth-pagination-signing-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "PAGINATION_SIGNING_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Required for signing new keyset pagination cursors."
      },
      {
        "id": "auth-admin-mfa-encryption-key",
        "kind": "secret",
        "worker": "auth",
        "name": "ADMIN_MFA_ENCRYPTION_KEY",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Required for encrypting new admin MFA TOTP secrets."
      },
      {
        "id": "auth-admin-mfa-proof-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "ADMIN_MFA_PROOF_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Required for signing new short-lived admin MFA proof cookies."
      },
      {
        "id": "auth-admin-mfa-recovery-hash-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "ADMIN_MFA_RECOVERY_HASH_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Required for hashing new admin MFA recovery codes."
      },
      {
        "id": "auth-ai-save-reference-signing-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "AI_SAVE_REFERENCE_SIGNING_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Required for signing new generated-image save references."
      },
      {
        "id": "auth-resend-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "RESEND_API_KEY",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Required for password reset and verification email delivery."
      },
      {
        "id": "auth-ai-service-auth-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "AI_SERVICE_AUTH_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Required for HMAC signing of auth-worker requests to the internal AI worker. Must match the AI worker AI_SERVICE_AUTH_SECRET before production deploy."
      },
      {
        "id": "auth-billing-webhook-test-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "BILLING_WEBHOOK_TEST_SECRET",
        "requiredForRelease": false,
        "documentation": "PHASE2I_BILLING_EVENT_INGESTION_REPORT.md",
        "summary": "Optional Phase 2-I synthetic billing webhook verification secret. If absent, the test-only webhook route fails closed; live payment providers remain disabled."
      },
      {
        "id": "auth-stripe-secret-key",
        "kind": "secret",
        "worker": "auth",
        "name": "STRIPE_SECRET_KEY",
        "requiredForRelease": false,
        "documentation": "PHASE2J_STRIPE_TESTMODE_CREDIT_PACK_CHECKOUT_REPORT.md",
        "summary": "Optional Phase 2-J Stripe Testmode secret key. Required only to create Stripe Testmode credit-pack Checkout Sessions; live keys are rejected."
      },
      {
        "id": "auth-stripe-webhook-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "STRIPE_WEBHOOK_SECRET",
        "requiredForRelease": false,
        "documentation": "PHASE2J_STRIPE_TESTMODE_CREDIT_PACK_CHECKOUT_REPORT.md",
        "summary": "Optional Phase 2-J Stripe Testmode webhook endpoint secret. Required only for the Stripe Testmode webhook route; live webhook side effects remain disabled."
      },
      {
        "id": "auth-stripe-mode-var",
        "kind": "dashboard_setting",
        "worker": "auth",
        "name": "STRIPE_MODE",
        "requiredForRelease": false,
        "documentation": "PHASE2J_STRIPE_TESTMODE_CREDIT_PACK_CHECKOUT_REPORT.md",
        "summary": "Optional Phase 2-J Stripe mode flag. The only accepted value for checkout/webhook side effects in this phase is test."
      },
      {
        "id": "auth-enable-admin-stripe-test-checkout-var",
        "kind": "dashboard_setting",
        "worker": "auth",
        "name": "ENABLE_ADMIN_STRIPE_TEST_CHECKOUT",
        "requiredForRelease": false,
        "documentation": "PHASE2K_ADMIN_STRIPE_TESTMODE_LOCKDOWN_REPORT.md",
        "summary": "Optional Phase 2-K operator-controlled kill switch. Stripe Testmode checkout creation is disabled unless this value is exactly true; unrelated routes and verified webhook processing remain deployable with it absent."
      },
      {
        "id": "auth-stripe-checkout-success-url-var",
        "kind": "dashboard_setting",
        "worker": "auth",
        "name": "STRIPE_CHECKOUT_SUCCESS_URL",
        "requiredForRelease": false,
        "documentation": "PHASE2J_STRIPE_TESTMODE_CREDIT_PACK_CHECKOUT_REPORT.md",
        "summary": "Optional Phase 2-J HTTPS success URL used only by Stripe Testmode Checkout Session creation."
      },
      {
        "id": "auth-stripe-checkout-cancel-url-var",
        "kind": "dashboard_setting",
        "worker": "auth",
        "name": "STRIPE_CHECKOUT_CANCEL_URL",
        "requiredForRelease": false,
        "documentation": "PHASE2J_STRIPE_TESTMODE_CREDIT_PACK_CHECKOUT_REPORT.md",
        "summary": "Optional Phase 2-J HTTPS cancel URL used only by Stripe Testmode Checkout Session creation."
      },
      {
        "id": "auth-enable-live-stripe-credit-packs-var",
        "kind": "dashboard_setting",
        "worker": "auth",
        "name": "ENABLE_LIVE_STRIPE_CREDIT_PACKS",
        "requiredForRelease": false,
        "documentation": "PHASE2L_LIVE_STRIPE_CREDIT_PACKS_AND_CREDITS_DASHBOARD_REPORT.md",
        "summary": "Optional Phase 2-L operator-controlled live credit-pack kill switch. Live checkout creation is disabled unless this value is exactly true; unrelated routes and verified Testmode behavior remain deployable with it absent."
      },
      {
        "id": "auth-stripe-live-secret-key",
        "kind": "secret",
        "worker": "auth",
        "name": "STRIPE_LIVE_SECRET_KEY",
        "requiredForRelease": false,
        "documentation": "PHASE2L_LIVE_STRIPE_CREDIT_PACKS_AND_CREDITS_DASHBOARD_REPORT.md",
        "summary": "Optional Phase 2-L live Stripe secret key. Required only when ENABLE_LIVE_STRIPE_CREDIT_PACKS=true; Testmode keys are rejected."
      },
      {
        "id": "auth-stripe-live-webhook-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "STRIPE_LIVE_WEBHOOK_SECRET",
        "requiredForRelease": false,
        "documentation": "PHASE2L_LIVE_STRIPE_CREDIT_PACKS_AND_CREDITS_DASHBOARD_REPORT.md",
        "summary": "Optional Phase 2-L live Stripe webhook endpoint secret. Required for POST /api/billing/webhooks/stripe/live and now required before live credit-pack Checkout Session creation so checkout fails closed unless webhook credit-grant readiness is configured."
      },
      {
        "id": "auth-stripe-live-checkout-success-url-var",
        "kind": "dashboard_setting",
        "worker": "auth",
        "name": "STRIPE_LIVE_CHECKOUT_SUCCESS_URL",
        "requiredForRelease": false,
        "documentation": "PHASE2L_LIVE_STRIPE_CREDIT_PACKS_AND_CREDITS_DASHBOARD_REPORT.md",
        "summary": "Optional Phase 2-L HTTPS success URL used only by live Stripe credit-pack Checkout Session creation. Public Pricing checkout should use https://bitbi.ai/pricing.html?checkout=success."
      },
      {
        "id": "auth-stripe-live-checkout-cancel-url-var",
        "kind": "dashboard_setting",
        "worker": "auth",
        "name": "STRIPE_LIVE_CHECKOUT_CANCEL_URL",
        "requiredForRelease": false,
        "documentation": "PHASE2L_LIVE_STRIPE_CREDIT_PACKS_AND_CREDITS_DASHBOARD_REPORT.md",
        "summary": "Optional Phase 2-L HTTPS cancel URL used only by live Stripe credit-pack Checkout Session creation. Public Pricing checkout should use https://bitbi.ai/pricing.html?checkout=cancel."
      },
      {
        "id": "ai-service-auth-secret",
        "kind": "secret",
        "worker": "ai",
        "name": "AI_SERVICE_AUTH_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/ai/src/index.js",
        "summary": "Required for HMAC verification of internal AI worker requests. Must match the auth worker AI_SERVICE_AUTH_SECRET before production deploy."
      },
      {
        "id": "ai-vidu-api-key",
        "kind": "secret",
        "worker": "ai",
        "name": "VIDU_API_KEY",
        "requiredForRelease": false,
        "documentation": "AI_VIDEO_ASYNC_JOB_DESIGN.md",
        "summary": "Required for async Vidu Q3 Pro direct provider task create/poll support. Pixverse async jobs can run without it, but Vidu jobs fail safely if it is missing."
      },
      {
        "id": "contact-resend-secret",
        "kind": "secret",
        "worker": "contact",
        "name": "RESEND_API_KEY",
        "requiredForRelease": true,
        "documentation": "workers/contact/src/index.js",
        "summary": "Required for contact form email delivery."
      },
      {
        "id": "auth-images-enabled",
        "kind": "cloudflare_feature",
        "worker": "auth",
        "binding": "IMAGES",
        "requiredForRelease": true,
        "documentation": "docs/ai-image-derivatives-runbook.md",
        "summary": "Cloudflare Images must be enabled so the IMAGES binding can attach."
      },
      {
        "id": "auth-activity-ingest-queue-created",
        "kind": "cloudflare_queue",
        "worker": "auth",
        "binding": "ACTIVITY_INGEST_QUEUE",
        "queue": "bitbi-auth-activity-ingest",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "The auth activity ingest queue must exist before the auth worker deploy that enqueues admin audit and user activity events."
      },
      {
        "id": "auth-derivatives-queue-created",
        "kind": "cloudflare_queue",
        "worker": "auth",
        "binding": "AI_IMAGE_DERIVATIVES_QUEUE",
        "queue": "bitbi-ai-image-derivatives",
        "requiredForRelease": true,
        "documentation": "docs/ai-image-derivatives-runbook.md",
        "summary": "The derivative queue must exist before the auth worker config that references it is deployed."
      },
      {
        "id": "auth-ai-video-jobs-queue-created",
        "kind": "cloudflare_queue",
        "worker": "auth",
        "binding": "AI_VIDEO_JOBS_QUEUE",
        "queue": "bitbi-ai-video-jobs",
        "requiredForRelease": true,
        "documentation": "AI_VIDEO_ASYNC_JOB_DESIGN.md",
        "summary": "The async AI video jobs queue must exist before the auth worker deploy that enqueues admin video jobs."
      },
      {
        "id": "auth-audit-archive-bucket-created",
        "kind": "cloudflare_r2_bucket",
        "worker": "auth",
        "binding": "AUDIT_ARCHIVE",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "The private audit archive bucket must exist before the auth worker deploy that archives cold audit and activity logs."
      },
      {
        "id": "auth-sensitive-post-waf-rule",
        "kind": "dashboard_rule",
        "requiredForRelease": false,
        "documentation": "docs/cloudflare-rate-limiting-wave1.md",
        "summary": "The auth WAF rate limiting rule remains dashboard-managed and is not repo-enforced."
      },
      {
        "id": "static-security-transform-rules",
        "kind": "transform_rule",
        "requiredForRelease": false,
        "documentation": "docs/privacy-compliance-audit.md",
        "summary": "Static-site security headers still depend on Cloudflare Transform Rules configured outside the repo."
      },
      {
        "id": "cloudflare-rum-setting",
        "kind": "dashboard_setting",
        "requiredForRelease": false,
        "documentation": "docs/privacy-compliance-audit.md",
        "summary": "Cloudflare RUM remains a dashboard-only setting that must be reviewed manually."
      }
    ]
  },
  "assetVersion": {
    "placeholder": "__ASSET_VERSION__"
  },
