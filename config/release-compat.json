{
  "schemaVersion": 1,
  "release": {
    "schemaCheckpoints": {
      "auth": {
        "migrationDirectory": "workers/auth/migrations",
        "latest": "0076_add_fable_chat_web_fetch.sql",
        "databaseName": "bitbi-auth-db"
      }
    },
    "workers": {
      "ai": {
        "name": "bitbi-ai",
        "wranglerPath": "workers/ai/wrangler.jsonc",
        "workersDev": false,
        "previewUrls": false,
        "bindings": {
          "ai": "AI",
          "durableObjects": {
            "SERVICE_AUTH_REPLAY": {
              "className": "AiServiceAuthReplayDurableObject"
            }
          }
        },
        "migrations": [
          {
            "tag": "v1-service-auth-replay",
            "newSqliteClasses": ["AiServiceAuthReplayDurableObject"]
          }
        ]
      },
      "auth": {
        "name": "bitbi-auth",
        "wranglerPath": "workers/auth/wrangler.jsonc",
        "vars": ["APP_BASE_URL", "APP_ALLOWED_ORIGINS", "RESEND_FROM_EMAIL", "BITBI_ENV", "ENABLE_ADMIN_AI_XAI_IMAGE_BUDGET"],
        "expectedVars": {
          "APP_BASE_URL": "https://bitbi.ai",
          "APP_ALLOWED_ORIGINS": "https://bitbi.ai,https://van-ark.com",
          "RESEND_FROM_EMAIL": "BITBI <noreply@contact.bitbi.ai>",
          "BITBI_ENV": "production",
          "ENABLE_ADMIN_AI_XAI_IMAGE_BUDGET": "true"
        },
        "triggers": {
          "crons": ["0 3 * * *"]
        },
        "routes": [
          {
            "pattern": "bitbi.ai/api/*",
            "zone_name": "bitbi.ai"
          }
        ],
        "bindings": {
          "ai": "AI",
          "images": "IMAGES",
          "d1": {
            "DB": {
              "databaseName": "bitbi-auth-db"
            }
          },
          "r2": {
            "PRIVATE_MEDIA": {
              "bucketName": "bitbi-private-media"
            },
            "USER_IMAGES": {
              "bucketName": "bitbi-user-images"
            },
            "AUDIT_ARCHIVE": {
              "bucketName": "bitbi-audit-archive"
            }
          },
          "services": {
            "AI_LAB": {
              "service": "bitbi-ai",
              "worker": "ai"
            }
          },
          "durableObjects": {
            "PUBLIC_RATE_LIMITER": {
              "className": "AuthPublicRateLimiterDurableObject"
            }
          },
          "queues": {
            "producers": {
              "ACTIVITY_INGEST_QUEUE": {
                "queue": "bitbi-auth-activity-ingest"
              },
              "AI_IMAGE_DERIVATIVES_QUEUE": {
                "queue": "bitbi-ai-image-derivatives"
              },
              "AI_VIDEO_JOBS_QUEUE": {
                "queue": "bitbi-ai-video-jobs"
              }
            },
            "consumers": [
              {
                "queue": "bitbi-auth-activity-ingest",
                "max_batch_size": 50,
                "max_batch_timeout": 5,
                "max_retries": 6
              },
              {
                "queue": "bitbi-ai-image-derivatives",
                "max_batch_size": 5,
                "max_batch_timeout": 5,
                "max_retries": 8
              },
              {
                "queue": "bitbi-ai-video-jobs",
                "max_batch_size": 3,
                "max_batch_timeout": 5,
                "max_retries": 4
              }
            ]
          }
        },
        "migrations": [
          {
            "tag": "v1-public-rate-limiter",
            "newSqliteClasses": ["AuthPublicRateLimiterDurableObject"]
          }
        ]
      },
      "contact": {
        "name": "bitbi-contact",
        "wranglerPath": "workers/contact/wrangler.jsonc",
        "vars": ["BITBI_ENV"],
        "expectedVars": {
          "BITBI_ENV": "production"
        },
        "workersDev": false,
        "routes": [
          {
            "pattern": "contact.bitbi.ai",
            "custom_domain": true
          }
        ],
        "bindings": {
          "durableObjects": {
            "PUBLIC_RATE_LIMITER": {
              "className": "ContactPublicRateLimiterDurableObject"
            }
          }
        },
        "migrations": [
          {
            "tag": "v1-public-rate-limiter",
            "newSqliteClasses": ["ContactPublicRateLimiterDurableObject"]
          }
        ]
      }
    },
    "services": {
      "homepage-ffmpeg-processor": {
        "name": "homepage-ffmpeg-processor",
        "type": "processor/service",
        "path": "services/homepage-ffmpeg-processor",
        "documentation": "docs/runbooks/HOMEPAGE_HERO_AND_MEMVID_STREAM_VIDEO_DERIVATIVES.md",
        "summary": "External ffmpeg processor for optimized Homepage Hero derivatives and optional short Memvid Stream preview preparation."
      }
    },
    "deployOrder": [
      {
        "id": "auth-migrations",
        "type": "schema-checkpoint",
        "checkpoint": "auth"
      },
      {
        "id": "ai-worker",
        "type": "worker",
        "worker": "ai"
      },
      {
        "id": "auth-worker",
        "type": "worker",
        "worker": "auth",
        "dependsOn": ["auth-migrations", "ai-worker"]
      },
      {
        "id": "contact-worker",
        "type": "worker",
        "worker": "contact"
      },
      {
        "id": "homepage-ffmpeg-processor",
        "type": "service",
        "service": "homepage-ffmpeg-processor",
        "dependsOn": ["auth-migrations", "auth-worker"]
      },
      {
        "id": "static-site",
        "type": "static",
        "dependsOn": ["auth-worker", "contact-worker", "homepage-ffmpeg-processor"]
      }
    ],
    "authAiCallerPolicy": {
      "version": "auth-ai-caller-policy-v1",
      "sharedPolicyFile": "workers/shared/ai-caller-policy.mjs",
      "aiPolicyFile": "workers/ai/src/lib/caller-policy.js",
      "authProxyFile": "workers/auth/src/lib/admin-ai-proxy.js",
      "deployOrder": ["ai-worker", "auth-worker"],
      "routes": [
        {
          "aiRoute": "/internal/ai/test-text",
          "allowedOperationIds": ["admin.text.test", "member.text.generate", "member.music.lyrics.generate"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/routes/admin-ai.js",
              "sourceRoute": "/api/admin/ai/test-text",
              "operationIds": ["admin.text.test"]
            },
            {
              "sourceFile": "workers/auth/src/routes/ai/text-generate.js",
              "sourceRoute": "/api/ai/generate-text",
              "operationIds": ["member.text.generate"],
              "operationIdReferences": ["AI_USAGE_OPERATIONS.MEMBER_TEXT_GENERATE.id"]
            },
            {
              "sourceFile": "workers/auth/src/routes/ai/music-generate.js",
              "sourceRoute": "/api/ai/generate-music",
              "operationIds": ["member.music.lyrics.generate"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/fable-chat",
          "allowedOperationIds": ["admin.fable_chat.send"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/lib/fable-chat-budget.js",
              "sourceRoute": "/api/admin/fable-chat/conversations/:id/messages",
              "operationIds": ["admin.fable_chat.send"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/fable-chat/stream",
          "allowedOperationIds": ["admin.fable_chat.send"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/lib/fable-chat-budget.js",
              "sourceRoute": "/api/admin/fable-chat/conversations/:id/messages/stream",
              "operationIds": ["admin.fable_chat.send"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/fable-chat/memory",
          "allowedOperationIds": ["admin.fable_chat.compact_memory"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/lib/fable-chat-memory-budget.js",
              "sourceRoute": "/api/admin/fable-chat/conversations/:id/messages",
              "operationIds": ["admin.fable_chat.compact_memory"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/test-image",
          "allowedOperationIds": ["admin.image.test.charged", "admin.image.test.unmetered"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/routes/admin-ai.js",
              "sourceRoute": "/api/admin/ai/test-image",
              "operationIds": ["admin.image.test.charged", "admin.image.test.unmetered"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/test-embeddings",
          "allowedOperationIds": ["admin.embeddings.test"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/routes/admin-ai.js",
              "sourceRoute": "/api/admin/ai/test-embeddings",
              "operationIds": ["admin.embeddings.test"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/test-music",
          "allowedOperationIds": ["admin.music.test", "member.music.audio.generate"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/routes/admin-ai.js",
              "sourceRoute": "/api/admin/ai/test-music",
              "operationIds": ["admin.music.test"]
            },
            {
              "sourceFile": "workers/auth/src/routes/ai/music-generate.js",
              "sourceRoute": "/api/ai/generate-music",
              "operationIds": ["member.music.audio.generate"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/compare",
          "allowedOperationIds": ["admin.compare"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/routes/admin-ai.js",
              "sourceRoute": "/api/admin/ai/compare",
              "operationIds": ["admin.compare"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/test-video",
          "allowedOperationIds": ["admin.video.sync_debug"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/routes/admin-ai.js",
              "sourceRoute": "/api/admin/ai/test-video",
              "operationIds": ["admin.video.sync_debug"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/video-task/create",
          "allowedOperationIds": ["admin.video.task.create"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/lib/ai-video-jobs.js",
              "sourceRoute": "AI_VIDEO_JOBS_QUEUE",
              "operationIds": ["admin.video.task.create"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/video-task/poll",
          "allowedOperationIds": ["admin.video.task.poll"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/lib/ai-video-jobs.js",
              "sourceRoute": "AI_VIDEO_JOBS_QUEUE",
              "operationIds": ["admin.video.task.poll"]
            }
          ]
        },
        {
          "aiRoute": "/internal/ai/live-agent",
          "allowedOperationIds": ["admin.live_agent"],
          "authSources": [
            {
              "sourceFile": "workers/auth/src/routes/admin-ai.js",
              "sourceRoute": "/api/admin/ai/live-agent",
              "operationIds": ["admin.live_agent"]
            }
          ]
        }
      ]
    },
    "manualPrerequisites": [
      {
        "id": "auth-session-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "SESSION_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Legacy compatibility fallback for pre-Phase 1-D sessions, admin MFA material, cursors, and generated image save references. Keep until the legacy security-secret fallback is intentionally disabled after the migration window."
      },
      {
        "id": "auth-session-hash-secret",
        "kind": "secret",
        "worker": "auth",
        "name": "SESSION_HASH_SECRET",
        "requiredForRelease": true,
        "documentation": "workers/auth/CLAUDE.md",
        "summary": "Required for hashing new auth session tokens. New sessions must not use SESSION_SECRET."
      },
      {
        "id": "auth-pagination-signing-secret",
